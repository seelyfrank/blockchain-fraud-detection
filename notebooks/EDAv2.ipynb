    "### Isolation Forest"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 61,
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "anomaly_score\n",
       " 1    99001\n",
       "-1      999\n",
       "Name: count, dtype: int64"
      ]
     },
     "execution_count": 61,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "from sklearn.ensemble import IsolationForest\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.model_selection import cross_val_score\n",
    "\n",
    "# Some additional features to train on\n",
    "df['gas_fee_ratio'] = df['gas_price'] / df['gas_used']\n",
    "df['txn_speed'] = df['gas_price'] * df['gas_used']\n",
    "\n",
    "# preprocess\n",
    "features = ['value', 'gas_price', 'gas_used', 'gas_fee_ratio', 'txn_speed']\n",
    "df_features = df[features].copy()\n",
    "\n",
    "scaler = StandardScaler()\n",
    "df_features = scaler.fit_transform(df_features)\n",
    "\n",
    "model = IsolationForest(n_estimators=1000, max_samples='auto', contamination=0.01, random_state=42)\n",
    "df['anomaly_score'] = model.fit_predict(df_features)\n",
    "df['anomaly_score'].value_counts()"
   ]
  },
